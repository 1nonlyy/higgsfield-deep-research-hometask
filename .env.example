# Copy to `.env` in this directory, then replace the placeholder with your key.
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=paste-your-anthropic-api-key-here

# Optional overrides (defaults are claude-haiku-4-5):
# DRL_MODEL=claude-haiku-4-5
# DRL_SMALL_MODEL=claude-haiku-4-5
# DRL_MAX_STEPS=12
# Soft-eval judge (default matches agent Haiku 4.5; legacy Haiku 3/3.5 IDs are retired on Anthropic):
# DRL_JUDGE_MODEL=claude-haiku-4-5
